generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CheckIn {
  id            String   @id @default(cuid())
  date          String   @unique
  sleepQuality  Int      
  mood          String   
  trouble       String?  
  expectation   String?  
  word          String?  
  summary       String   
  encouragement String   
  createdAt     DateTime @default(now())
}
