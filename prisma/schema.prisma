generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CheckIn {
  id            String   @id @default(cuid())
  date          String   
  time          String   
  answersJson   String   
  summary       String   
  encouragement String   
  book          String   @default("")
  createdAt     DateTime @default(now())
}
